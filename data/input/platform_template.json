{
  "platform": "demo_site",
  "request_headers": {
    "User-Agent": "Mozilla/5.0"
  },
  "list_page": {
    "base_url": "https://www.example.com",
    "item_selector": "div.REPLACE_ITEM_SELECTOR",
    "detail_link_selector": "a.REPLACE_LINK_SELECTOR",
    "detail_link_attr": "href"
  },
  "detail_page": {
    "single_selectors": {
      "job_title_raw": [
        "h1.REPLACE_JOB_TITLE"
      ],
      "company_name_raw": [
        "div.REPLACE_COMPANY_NAME"
      ],
      "city_raw": [
        "span.REPLACE_CITY"
      ],
      "salary_raw": [
        "span.REPLACE_SALARY"
      ],
      "education_raw": [
        "span.REPLACE_EDUCATION"
      ],
      "experience_raw": [
        "span.REPLACE_EXPERIENCE"
      ],
      "company_industry_raw": [
        "div.REPLACE_COMPANY_INDUSTRY"
      ],
      "company_size_raw": [
        "div.REPLACE_COMPANY_SIZE"
      ]
    },
    "multi_selectors": {
      "job_tags_raw": [
        "div.REPLACE_JOB_TAGS span"
      ],
      "jd_text_raw": [
        "div.REPLACE_JOB_DESCRIPTION"
      ]
    }
  }
}
